# LLM
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/finrag

# Redis
REDIS_URL=redis://localhost:6379

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# LangSmith tracing (optional). Set the API key from https://smith.langchain.com
# to send RAG + judge traces to LangSmith. Leave blank to disable.
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=financial-rag-eval
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
